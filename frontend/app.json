{
  "expo": {
    "name": "NoteHub",
    "slug": "notehub",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#0A0A0F"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "expo-router",
      [
        "expo-camera",
        {
          "cameraPermission": "NoteHub needs camera access to capture notes from your surroundings."
        }
      ],
      [
        "expo-media-library",
        {
          "photosPermission": "NoteHub needs access to your photos to save captures.",
          "savePhotosPermission": "NoteHub needs access to save photos.",
          "isAccessMediaLocationEnabled": true
        }
      ]
    ],
    "scheme": "notehub",
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#0A0A0F"
      },
      "package": "com.notehub.app",
      "permissions": [
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.WRITE_EXTERNAL_STORAGE",
        "android.permission.ACCESS_MEDIA_LOCATION"
      ]
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.notehub.app"
    },
    "web": {
      "bundler": "metro",
      "output": "single"
    },
    "experiments": {
      "typedRoutes": true
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "e911fbe2-3f3f-4f96-a880-f391ae2a8868"
      }
    }
  }
}
