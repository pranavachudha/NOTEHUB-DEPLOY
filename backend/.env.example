# NoteHub Backend Environment Variables

# Security
SECRET_KEY=notehub-dev-secret-key-change-this-in-production

# Database
DB_PATH=notehub.db

# Optional Supabase Free Database Sync (For 100% Free & Permanent Cloud Storage on Render)
# Create a free project on supabase.com, then a bucket named 'backups' in Storage
SUPABASE_URL=https://your_supabase_project_url.supabase.co
SUPABASE_KEY=your_supabase_anon_public_key_here

# Primary AI OCR Engine (Recommended)
# Get a key from Google AI Studio: https://aistudio.google.com/
GEMINI_API_KEY=your_gemini_api_key_here

# Local Fallback OCR Engine (Ollama)
OLLAMA_URL=http://localhost:11434
OLLAMA_MODEL=llava

# Email Verification (SMTP)
# Leave blank to use MOCK email verification (OTP code will print in terminal logs)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASSWORD=your_app_specific_password_here
